[]<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Golden Spoon | Luxury Restaurant</title>

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
scroll-behavior:smooth;
}

body{
font-family:'Poppins',sans-serif;
background:#0f0f0f;
color:white;
}

nav{
position:fixed;
top:0;
width:100%;
display:flex;
justify-content:space-between;
align-items:center;
padding:20px 8%;
background:rgba(0,0,0,0.9);
backdrop-filter:blur(10px);
z-index:1000;
}

.logo{
font-size:32px;
font-family:'Cormorant Garamond',serif;
color:#d4af37;
font-weight:bold;
}

nav ul{
display:flex;
list-style:none;
gap:30px;
}

nav a{
text-decoration:none;
color:white;
transition:0.3s;
}

nav a:hover{
color:#d4af37;
}

.hero{
height:100vh;
background:
linear-gradient(rgba(0,0,0,.55),rgba(0,0,0,.6)),
url('https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?auto=format&fit=crop&w=1600&q=80');
background-size:cover;
background-position:center;
display:flex;
justify-content:center;
align-items:center;
text-align:center;
padding:20px;
}

.hero-content h1{
font-size:5rem;
font-family:'Cormorant Garamond',serif;
color:#d4af37;
}

.hero-content p{
font-size:1.2rem;
max-width:700px;
margin:20px auto;
}

.btn{
display:inline-block;
padding:15px 35px;
background:#d4af37;
color:black;
font-weight:600;
text-decoration:none;
border-radius:50px;
margin-top:20px;
}

section{
padding:100px 8%;
}

.section-title{
text-align:center;
font-size:3rem;
margin-bottom:50px;
font-family:'Cormorant Garamond',serif;
color:#d4af37;
}

.about{
display:grid;
grid-template-columns:1fr 1fr;
gap:50px;
align-items:center;
}

.about img{
width:100%;
border-radius:20px;
}

.gallery{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
gap:25px;
}

.gallery img{
width:100%;
height:300px;
object-fit:cover;
border-radius:20px;
transition:.4s;
}

.gallery img:hover{
transform:scale(1.05);
}

.menu-grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:25px;
}

.menu-card{
background:#1b1b1b;
padding:25px;
border-radius:20px;
border:1px solid rgba(212,175,55,.3);
}

.menu-card h3{
color:#d4af37;
margin-bottom:10px;
}

.delivery{
text-align:center;
background:#171717;
border-radius:25px;
}

.delivery img{
width:100%;
max-width:700px;
border-radius:20px;
margin-top:30px;
}

.testimonials{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
gap:25px;
}

.review{
background:#1b1b1b;
padding:25px;
border-radius:20px;
}

.contact{
display:grid;
grid-template-columns:1fr 1fr;
gap:50px;
}

form input,
form textarea{
width:100%;
padding:15px;
margin-bottom:15px;
border:none;
border-radius:10px;
background:#1b1b1b;
color:white;
}

form button{
padding:15px 35px;
background:#d4af37;
border:none;
border-radius:50px;
font-weight:bold;
cursor:pointer;
}

footer{
padding:30px;
text-align:center;
background:black;
color:#aaa;
}

@media(max-width:768px){

.hero-content h1{
font-size:3rem;
}

.about,
.contact{
grid-template-columns:1fr;
}

nav ul{
display:none;
}
}
</style>
</head>

<body>

<nav>
<div class="logo">Golden Spoon</div>
<ul>
<li><a href="#about">About</a></li>
<li><a href="#gallery">Gallery</a></li>
<li><a href="#menu">Menu</a></li>
<li><a href="#delivery">Delivery</a></li>
<li><a href="#contact">Contact</a></li>
</ul>
</nav>

<section class="hero">
<div class="hero-content">
<h1>Luxury Dining Experience</h1>
<p>Experience gourmet flavors crafted by world-class chefs in an elegant atmosphere designed for unforgettable moments.</p>
<a href="#menu" class="btn">Explore Menu</a>
</div>
</section>

<section id="about">
<h2 class="section-title">About Us</h2>

<div class="about">
<img src="https://images.unsplash.com/photo-1552566626-52f8b828add9?auto=format&fit=crop&w=1200&q=80">

<div>
<h3 style="color:#d4af37;font-size:2rem;margin-bottom:20px;">
A Taste of Luxury
</h3>

<p>
Golden Spoon combines fine dining with modern culinary artistry.
Every dish is crafted from premium ingredients and served in a sophisticated environment.
</p>
</div>
</div>
</section>

<section id="gallery">
<h2 class="section-title">Food Gallery</h2>

<div class="gallery">

<img src="https://images.unsplash.com/photo-1544025162-d76694265947?auto=format&fit=crop&w=1200&q=80">

<img src="https://images.unsplash.com/photo-1555939594-58d7cb561ad1?auto=format&fit=crop&w=1200&q=80">

<img src="https://images.unsplash.com/photo-1565299624946-b28f40a0ae38?auto=format&fit=crop&w=1200&q=80">

<img src="https://images.unsplash.com/photo-1559847844-d721426d6edc?auto=format&fit=crop&w=1200&q=80">

</div>
</section>

<section id="menu">
<h2 class="section-title">Signature Menu</h2>

<div class="menu-grid">

<div class="menu-card">
<h3>Truffle Pasta</h3>
<p>Rich creamy pasta infused with premium black truffle.</p>
</div>

<div class="menu-card">
<h3>Luxury Burger</h3>
<p>Grilled beef, aged cheddar and gourmet sauces.</p>
</div>

<div class="menu-card">
<h3>Seafood Delight</h3>
<p>Fresh seafood served with signature herbs.</p>
</div>

<div class="menu-card">
<h3>Chocolate Royale</h3>
<p>Luxury dessert crafted for sweet perfection.</p>
</div>

</div>
</section>

<section id="delivery">
<h2 class="section-title">Online Delivery</h2>

<div class="delivery">
<h3 style="font-size:2rem;color:#d4af37;">
Fast Delivery At Your Doorstep
</h3>

<p style="margin-top:15px;">
Order directly from our website or delivery partners and enjoy restaurant-quality meals at home.
</p>

<img src="https://images.unsplash.com/photo-1526367790999-0150786686a2?auto=format&fit=crop&w=1200&q=80">

<br>
<a href="#" class="btn">Order Now</a>
</div>
</section>

<section>
<h2 class="section-title">Customer Reviews</h2>

<div class="testimonials">

<div class="review">
★★★★★
<p style="margin-top:15px;">
Amazing atmosphere and exceptional food quality.
</p>
</div>

<div class="review">
★★★★★
<p style="margin-top:15px;">
The best luxury dining experience in the city.
</p>
</div>

<div class="review">
★★★★★
<p style="margin-top:15px;">
Beautiful presentation and outstanding service.
</p>
</div>

</div>
</section>

<section id="contact">
<h2 class="section-title">Contact Us</h2>

<div class="contact">

<div>
<h3 style="color:#d4af37;font-size:2rem;">
Visit Us
</h3>

<p style="margin-top:20px;">
📍 123 Luxury Street<br>
New Delhi, India
</p>

<p style="margin-top:15px;">
📞 +91 98765 43210
</p>

<p style="margin-top:15px;">
✉ info@goldenspoon.com
</p>
</div>

<form>
<input type="text" placeholder="Your Name">
<input type="email" placeholder="Your Email">
<textarea rows="5" placeholder="Message"></textarea>
<button type="submit">Send Message</button>
</form>

</div>
</section>

<footer>
© 2026 Golden Spoon Restaurant. All Rights Reserved.
</footer>

</body>
</html>